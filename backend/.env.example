# Hermes Agent Web Chat — Backend Configuration
# Copy this file to .env and fill in your values.
#   cp backend/.env.example backend/.env

# Required: Login password for the web interface.
AUTH_PASSWORD=changeme

# Optional: Hermes Agent paths (defaults to ~/.hermes)
# HERMES_HOME=/home/user/.hermes
# HERMES_SRC=/home/user/.hermes/hermes-agent

# Optional: HTTP listen port (default: 11300)
# PORT=11300

# Optional: Enable debug endpoints (/api/debug/*)
# DEBUG=false
